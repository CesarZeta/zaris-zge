# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
# Excepcion: web-app/dist es el build del shell React que GitHub Pages publica
# (ver .github/workflows/deploy-web-app.yml). Versionado intencional.
!web-app/dist/
!web-app/dist/**
env/
venv/
.venv/

# Backend secrets
backend/.env
backend/.env.local

# IDE
.vscode/
.idea/

# Agent (Antigravity)
.agent/

# OS
Thumbs.db
.DS_Store

# Documentos técnicos (no deployar)
*.docx
ZARIS_REFERENCIA_PROYECTO.md

# SQL scripts (no van al frontend)
sql/

# Deploy scripts
deploy_to_supabase.py

# Temp
*.tmp
*.log
*.err
uvicorn.*

# Uploads mock (tramites, local storage)
backend/uploads/

# Documentos archivados con info sensible (no versionar)
docs/archivo/

# Config local de Claude Code (no versionar)
.claude/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
